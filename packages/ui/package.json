        "embla-carousel-react": "^8.6.0",
        "input-otp": "^1.4.2",
        "next-themes": "^0.4.6",
        "react": "19.2.4",
        "react-day-picker": "^10.0.1",
        "react-dom": "19.2.4",
        "react-resizable-panels": "^4.12.1",
        "recharts": "^3.8.0",
        "shadcn": "^4.13.0",
