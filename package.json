{
    "name": "infrastack-monorepo",
    "version": "0.0.1",
    "private": true,
    "description": "Infrastack monorepo — a code-first deployment platform for self-hosting apps.",
    "license": "MIT",
    "author": "Infrastack contributors",
    "homepage": "https://github.com/linuskang/infrastack#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/linuskang/infrastack.git"
    },
    "bugs": {
        "url": "https://github.com/linuskang/infrastack/issues"
    },
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev",
        "lint": "turbo lint",
        "format": "turbo format",
        "typecheck": "turbo typecheck --filter=infrastack --filter=@infrastack/backend --filter=@infrastack/worker --filter=@infrastack/caddy --filter=@infrastack/demo"
    },
    "devDependencies": {
        "@workspace/eslint-config": "*",
        "@workspace/typescript-config": "*",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "turbo": "^2.9.18",
        "typescript": "^5"
    },
    "packageManager": "npm@11.3.0",
    "engines": {
        "node": ">=20"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ]
}
