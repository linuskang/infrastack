{
  "name": "@infrastack/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env INFRASTACK_DATA_DIR=../../data tsx watch src/index.ts",
    "build": "tsc",
    "start": "cross-env INFRASTACK_DATA_DIR=../../data node dist/index.js",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@infrastack/backend": "*",
    "@infrastack/caddy": "*",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.4",
    "typescript": "^5"
  }
}
