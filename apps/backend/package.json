{
    "name": "@infrastack/backend",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "description": "Infrastack control plane (Hono + SQLite).",
    "license": "MIT",
    "author": "Infrastack contributors",
    "homepage": "https://github.com/linuskang/infrastack#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/linuskang/infrastack.git",
        "directory": "apps/backend"
    },
    "bugs": {
        "url": "https://github.com/linuskang/infrastack/issues"
    },
    "exports": {
        "./db": "./dist/db.js"
    },
    "scripts": {
        "dev": "cross-env INFRASTACK_DATA_DIR=../../data tsx watch src/index.ts",
        "build": "tsc",
        "start": "cross-env INFRASTACK_DATA_DIR=../../data node dist/index.js",
        "lint": "eslint",
        "format": "prettier --write \"**/*.{ts,tsx}\"",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@hono/node-server": "^1.14.1",
        "better-sqlite3": "^12.1.0",
        "hono": "^4.7.7",
        "zod": "^3.25.7"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^20",
        "@workspace/eslint-config": "*",
        "@workspace/typescript-config": "*",
        "cross-env": "^7.0.3",
        "tsx": "^4.19.4",
        "typescript": "^5"
    }
}
